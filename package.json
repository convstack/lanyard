{
	"name": "@convention/lanyard",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"start": "bun run server.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun run src/db/migrate.ts",
		"db:push": "drizzle-kit push",
		"db:seed": "bun run src/db/seed.ts",
		"db:studio": "drizzle-kit studio",
		"lanyard:setup": "bun run src/cli/bootstrap.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"docker:up": "docker compose -f deploy/docker/docker-compose.yml up -d --build --force-recreate",
		"docker:down": "docker compose -f deploy/docker/docker-compose.yml down",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@better-auth/passkey": "^1.5.6",
		"@tanstack/react-router": "^1.168.2",
		"@tanstack/react-start": "^1.167.3",
		"bcryptjs": "^3.0.3",
		"better-auth": "^1.5.6",
		"clsx": "^2.1.1",
		"drizzle-orm": "1.0.0-beta.18-7eb39f0",
		"nanoid": "^5.1.7",
		"nodemailer": "^8.0.3",
		"pg": "^8.20.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bcryptjs": "^3.0.0",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"@types/nodemailer": "^7.0.11",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.0",
		"drizzle-kit": "1.0.0-beta.18-7eb39f0",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.1",
		"vitest": "^4.1.0"
	}
}
