{
	"compilerOptions": {
		"jsx": "react-jsx",
		"moduleResolution": "Bundler",
		"module": "ESNext",
		"target": "ES2022",
		"skipLibCheck": true,
		"strictNullChecks": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"types": ["vite/client"],
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": ["src/**/*", "vite.config.ts", "drizzle.config.ts"],
	"exclude": ["node_modules", "dist", "drizzle"]
}
